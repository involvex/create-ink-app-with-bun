{
	"name": "%NAME%",
	"author": "%AUTHOR%",
	"description": "%DESCRIPTION%",
	"version": "0.0.0",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": ""
	},
	"bin": {
		"%NAME%": "dist/cli.js"
	},
	"type": "module",
	"engines": {
		"node": ">=16"
	},
	"scripts": {
		"build": "bun build src/cli.tsx --outdir dist --target node",
		"start": "bun run src/cli.tsx",
		"dev": "bun run --hot src/cli.tsx",
		"format": "prettier --write .",
		"lint": "eslint src",
		"lint:fix": "eslint src --fix",
		"typecheck": "tsc --noEmit",
		"prebuild": "bun run format && bun run lint:fix && bun run typecheck"
	},
	"files": ["dist"],
	"dependencies": {
		"ink": "latest",
		"meow": "latest",
		"react": "latest",
		"ink-select-input": "latest",
		"ink-text-input": "latest",
		"react-devtools-core": "latest"
	},
	"devDependencies": {
		"@types/node": "latest",
		"@types/react": "latest",
		"@types/ink": "latest",
		"@types/ink-text-input": "latest",
		"@types/ink-select-input": "latest",
		"@involvex/prettier-config": "latest",
		"chalk": "latest",
		"eslint-plugin-react": "latest",
		"eslint-plugin-react-hooks": "latest",
		"ink-testing-library": "^3.0.0",
		"prettier": "latest",
		"ts-node": "latest",
		"typescript": "latest",
		"eslint": "latest",
		"jiti": "latest",
		"@eslint/js": "latest",
		"globals": "latest",
		"@typescript-eslint/eslint-plugin": "latest",
		"@typescript-eslint/parser": "latest",
		"prettier-plugin-organize-imports": "^4.3.0",
		"prettier-plugin-packagejson": "^3.0.0",
		"prettier-plugin-sort-imports": "^1.8.10"
	},
	"prettier": "@involvex/prettier-config"
}
