{
	"name": "create-ink-app-with-bun",
	"version": "3.0.6",
	"description": "Generate a starter Ink app with Bun",
	"keywords": [
		"ink",
		"ink-app",
		"cli"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/involvex/create-ink-app-with-bun.git"
	},
	"funding": {
		"url": "https://github.com/sponsors/involvex"
	},
	"license": "MIT",
	"author": {
		"name": "involvex"
	},
	"type": "module",
	"bin": {
		"create-ink-app-with-bun": "cli.js"
	},
	"files": [
		"index.js",
		"cli.js",
		"templates"
	],
	"scripts": {
		"dev": "bun run cli.js",
		"format": "prettier --write .",
